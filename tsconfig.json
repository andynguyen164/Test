{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["tests/**/*.ts", "utils/**/*.ts", "scripts/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist", "reports", "playwright-report"]
}
